#!/bin/bash


function rows_for() {


	local country="$1"
	tail -n +2 worldcities.csv | grep -F ",$country,"

}

function count() {

	rows_for "$1" | wc -l 

}

function total() {
	
	awk -F',' -v c="$1" '$4==c { s += ($8==""?0:$8) } END{print s}' worldcities.csv

}

function sum() {

	local total=0
	local line
	while IFS= read -r line; do
		if [ "$line" -eq "$line" ] 2>/dev/null; then
			total=$(( total + line ))
		fi
	done
	
	echo "$total"

}

function average() {

	local n t

	n="$(count "$country")"
	t="$(total "$country")"
	
	echo "$(( t / n ))"

}

cmd="$1"

country="$2"

usage() {

	echo "Usage: "$0" [count||total||average] Country (example: analyze total Canada)" 

}

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
	usage
	exit 0
fi

if [ "$#" -ne 2 ]; then
	echo "Error: expected exactly two arguments" >&2
	echo "Try: "$0" -h" >&2
       exit 1
fi       

case "$cmd" in

	count) 
		count "$country"
		;;
	total)
		total "$country"
		;;
	average)
		average "$country"
		;;
	*)
		usage
    		exit 1
    		;;
esac
